# Discord
DISCORD_TOKEN=your_discord_bot_token
DISCORD_APPLICATION_ID=your_discord_application_id
DISCORD_PUBLIC_KEY=your_discord_public_key
# Optional: 빠른 테스트용 길드 커맨드 등록
DISCORD_GUILD_ID=your_test_guild_id

# Gemini
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash

# Vercel KV (production 권장)
KV_REST_API_URL=your_kv_rest_api_url
KV_REST_API_TOKEN=your_kv_rest_api_token

# Google Calendar (서비스 계정)
GCAL_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GCAL_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GCAL_CALENDAR_ID=primary_or_calendar_id
GCAL_TIMEZONE=Asia/Seoul
GCAL_TZ_OFFSET=+09:00
